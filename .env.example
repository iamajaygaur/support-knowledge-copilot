GOOGLE_API_KEY=your-google-ai-studio-key-here
# Local embedded Qdrant (default). Leave set for zero-Docker demos.
QDRANT_PATH=data/qdrant
# To use Docker Qdrant instead, set QDRANT_PATH= and:
# QDRANT_URL=http://localhost:6333
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=support_chunks
EMBEDDING_MODEL=gemini-embedding-001
LLM_MODEL=gemini-flash-latest
BM25_PATH=data/bm25/index.pkl
DENSE_K=10
SPARSE_K=10
RRF_K=60
RERANK_POOL=20
FINAL_K=5
RETRIEVAL_CONFIDENCE_THRESHOLD=0.25
